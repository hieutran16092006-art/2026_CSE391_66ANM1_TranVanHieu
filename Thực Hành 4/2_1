<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký tài khoản</title>

    <style>
        body {
            font-family: Arial;
            background: #f4f6f9;
            display: flex;
            justify-content: center;
            padding: 30px;
        }

        .container {
            background: white;
            padding: 25px;
            border-radius: 10px;
            width: 420px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
        }

        .field {
            margin-bottom: 15px;
        }

        label {
            font-weight: bold;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 8px;
            margin-top: 5px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        .gender-group {
            margin-top: 5px;
        }

        .gender-group label {
            margin-right: 10px;
        }

        .error {
            color: red;
            font-size: 13px;
        }

        button {
            width: 100%;
            padding: 10px;
            background: #2d8cff;
            border: none;
            color: white;
            border-radius: 6px;
            font-size: 16px;
        }

        button:hover {
            background: #1c6fe0;
        }

        #success {
            display: none;
            text-align: center;
            font-size: 20px;
            color: green;
            margin-top: 20px;
        }
    </style>
</head>

<body>

    <div class="container">

        <h2>Tạo tài khoản</h2>

        <form id="form">

            <div class="field">
                <label>Họ và tên</label>
                <input type="text" id="fullname">
                <div class="error" id="fullnameError"></div>
            </div>

            <div class="field">
                <label>Email</label>
                <input type="text" id="email">
                <div class="error" id="emailError"></div>
            </div>

            <div class="field">
                <label>Số điện thoại</label>
                <input type="text" id="phone">
                <div class="error" id="phoneError"></div>
            </div>

            <div class="field">
                <label>Mật khẩu</label>
                <input type="password" id="password">
                <div class="error" id="passwordError"></div>
            </div>

            <div class="field">
                <label>Xác nhận mật khẩu</label>
                <input type="password" id="confirmPassword">
                <div class="error" id="confirmPasswordError"></div>
            </div>

            <div class="field">
                <label>Giới tính</label>

                <div class="gender-group">
                    <label><input type="radio" name="gender" value="Nam"> Nam</label>
                    <label><input type="radio" name="gender" value="Nữ"> Nữ</label>
                    <label><input type="radio" name="gender" value="Khác"> Khác</label>
                </div>

                <div class="error" id="genderError"></div>
            </div>

            <div class="field">
                <label>
                    <input type="checkbox" id="terms">
                    Tôi đồng ý với điều khoản sử dụng
                </label>

                <div class="error" id="termsError"></div>
            </div>

            <button type="submit">Đăng ký tài khoản</button>

        </form>

        <div id="success"></div>

    </div>

    <script>

        const form = document.getElementById("form")

        function showError(id, message) {
            document.getElementById(id + "Error").innerText = message
        }

        function clearError(id) {
            document.getElementById(id + "Error").innerText = ""
        }

        function validateFullname() {
            let v = fullname.value.trim()
            let regex = /^[A-Za-zÀ-ỹ\s]+$/

            if (v === "") {
                showError("fullname", "Họ và tên không được để trống")
                return false
            }
            if (v.length < 3) {
                showError("fullname", "Họ và tên phải từ 3 ký tự")
                return false
            }
            if (!regex.test(v)) {
                showError("fullname", "Chỉ chứa chữ cái và khoảng trắng")
                return false
            }
            clearError("fullname")
            return true
        }

        function validateEmail() {
            let v = email.value.trim()
            let regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/

            if (v === "") {
                showError("email", "Email không được để trống")
                return false
            }
            if (!regex.test(v)) {
                showError("email", "Email không đúng định dạng")
                return false
            }
            clearError("email")
            return true
        }

        function validatePhone() {
            let v = phone.value.trim()
            let regex = /^0\d{9}$/

            if (v === "") {
                showError("phone", "Số điện thoại không được để trống")
                return false
            }
            if (!regex.test(v)) {
                showError("phone", "Số điện thoại phải có 10 số và bắt đầu bằng 0")
                return false
            }
            clearError("phone")
            return true
        }

        function validatePassword() {
            let v = password.value
            let regex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$/

            if (v === "") {
                showError("password", "Mật khẩu không được để trống")
                return false
            }
            if (!regex.test(v)) {
                showError("password", "Mật khẩu phải có ít nhất 8 ký tự, gồm hoa, thường, số")
                return false
            }
            clearError("password")
            return true
        }

        function validateConfirmPassword() {
            let v = confirmPassword.value

            if (v === "") {
                showError("confirmPassword", "Vui lòng xác nhận mật khẩu")
                return false
            }
            if (v !== password.value) {
                showError("confirmPassword", "Mật khẩu xác nhận không khớp")
                return false
            }
            clearError("confirmPassword")
            return true
        }

        function validateGender() {
            let checked = document.querySelector('input[name="gender"]:checked')
            if (!checked) {
                showError("gender", "Vui lòng chọn giới tính")
                return false
            }
            clearError("gender")
            return true
        }

        function validateTerms() {
            if (!terms.checked) {
                showError("terms", "Bạn phải đồng ý điều khoản")
                return false
            }
            clearError("terms")
            return true
        }

        form.addEventListener("submit", function (e) {

            e.preventDefault()

            let ok =
                validateFullname() &
                validateEmail() &
                validatePhone() &
                validatePassword() &
                validateConfirmPassword() &
                validateGender() &
                validateTerms()

            if (ok) {

                let name = fullname.value.trim()

                form.style.display = "none"

                success.style.display = "block"

                success.innerHTML =
                    `Đăng ký thành công! 🎉<br>Chào mừng <b>${name}</b>`
            }

        })

        fullname.addEventListener("blur", validateFullname)
        email.addEventListener("blur", validateEmail)
        phone.addEventListener("blur", validatePhone)
        password.addEventListener("blur", validatePassword)
        confirmPassword.addEventListener("blur", validateConfirmPassword)

        fullname.addEventListener("input", () => clearError("fullname"))
        email.addEventListener("input", () => clearError("email"))
        phone.addEventListener("input", () => clearError("phone"))
        password.addEventListener("input", () => clearError("password"))
        confirmPassword.addEventListener("input", () => clearError("confirmPassword"))

        document.querySelectorAll('input[name="gender"]').forEach(item => {
            item.addEventListener("blur", validateGender)
            item.addEventListener("change", () => clearError("gender"))
        })

        terms.addEventListener("blur", validateTerms)
        terms.addEventListener("change", () => clearError("terms"))

    </script>

</body>

</html>
